---
import SectionHeading from './SectionHeading.astro';
import ScrollReveal from './ScrollReveal.astro';
import { pasos } from '../data/proceso';
---
<section id="proceso" class="py-20 lg:py-28 bg-bg-secondary relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionHeading
        subtitle="Simple y transparente"
        title="Como Trabajamos Contigo"
        description="Trabajar con nosotros es facil. En 4 pasos pasas de la idea al producto"
      />
    </ScrollReveal>

    <div class="max-w-5xl mx-auto">
      <!-- Desktop: horizontal timeline -->
      <div class="hidden lg:grid grid-cols-4 gap-0 relative">
        <!-- Connecting line -->
        <div class="absolute top-10 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-accent-cyan via-accent-purple to-accent-cyan"></div>

        {pasos.map((paso, i) => (
          <ScrollReveal delay={`${i * 150}ms`}>
            <div class="flex flex-col items-center text-center px-4">
              <!-- Step circle -->
              <div class="relative z-10 w-20 h-20 flex items-center justify-center rounded-full bg-gradient-to-br from-accent-cyan to-accent-purple mb-6 shadow-[0_0_20px_rgba(56,189,248,0.3)]">
                <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={paso.icon} />
                </svg>
              </div>
              <!-- Step number -->
              <span class="text-xs font-bold text-accent-cyan uppercase tracking-widest mb-2">Paso {paso.step}</span>
              <h3 class="text-xl font-bold text-text-primary mb-3">{paso.title}</h3>
              <p class="text-sm text-text-secondary leading-relaxed mb-4">{paso.description}</p>
              <!-- Step mini illustration -->
              <div class="mx-auto w-full max-w-[140px] h-16 rounded-lg bg-gradient-to-br from-accent-cyan/5 to-accent-purple/5 border border-border-glass/20 overflow-hidden p-2 flex items-center justify-center">
                {i === 0 && (
                  <div class="flex gap-1.5 items-center">
                    <div class="w-6 h-6 rounded-full bg-accent-cyan/20 flex items-center justify-center"><div class="w-2 h-2 rounded-full bg-accent-cyan/50"></div></div>
                    <div class="space-y-1"><div class="h-1 w-10 rounded bg-white/10"></div><div class="h-1 w-7 rounded bg-white/5"></div></div>
                  </div>
                )}
                {i === 1 && (
                  <div class="grid grid-cols-3 gap-1 w-full">
                    <div class="h-3 rounded bg-accent-purple/20"></div>
                    <div class="h-3 rounded bg-accent-cyan/20"></div>
                    <div class="h-3 rounded bg-accent-purple/15"></div>
                    <div class="h-3 rounded bg-accent-cyan/15"></div>
                    <div class="h-3 rounded bg-accent-purple/20"></div>
                    <div class="h-3 rounded bg-accent-cyan/20"></div>
                  </div>
                )}
                {i === 2 && (
                  <div class="w-full space-y-1">
                    <div class="flex gap-1"><div class="h-1.5 flex-1 rounded bg-accent-cyan/30"></div><div class="h-1.5 w-3 rounded bg-green-400/30"></div></div>
                    <div class="flex gap-1"><div class="h-1.5 flex-[2] rounded bg-accent-purple/20"></div><div class="h-1.5 flex-1 rounded bg-accent-cyan/20"></div></div>
                    <div class="flex gap-1"><div class="h-1.5 flex-1 rounded bg-green-400/20"></div><div class="h-1.5 flex-[2] rounded bg-accent-cyan/25"></div></div>
                  </div>
                )}
                {i === 3 && (
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-green-500/20 flex items-center justify-center">
                      <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </div>
                    <div class="h-1.5 w-10 rounded bg-green-400/30"></div>
                  </div>
                )}
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>

      <!-- Mobile: vertical timeline -->
      <div class="lg:hidden relative pl-12">
        <!-- Vertical line -->
        <div class="absolute top-0 bottom-0 left-5 w-px bg-gradient-to-b from-accent-cyan via-accent-purple to-accent-cyan"></div>

        {pasos.map((paso, i) => (
          <ScrollReveal delay={`${i * 100}ms`}>
            <div class={`relative ${i < pasos.length - 1 ? 'pb-10' : ''}`}>
              <!-- Step dot -->
              <div class="absolute -left-12 top-0 w-10 h-10 flex items-center justify-center rounded-full bg-gradient-to-br from-accent-cyan to-accent-purple shadow-[0_0_12px_rgba(56,189,248,0.3)]">
                <span class="text-sm font-bold text-white">{paso.step}</span>
              </div>
              <div class="glass p-6">
                <div class="flex items-center gap-3 mb-3">
                  <svg class="w-5 h-5 text-accent-cyan flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={paso.icon} />
                  </svg>
                  <h3 class="text-lg font-bold text-text-primary">{paso.title}</h3>
                </div>
                <p class="text-sm text-text-secondary leading-relaxed">{paso.description}</p>
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </div>
</section>
