---
import ScrollReveal from './ScrollReveal.astro';
import SectionHeading from './SectionHeading.astro';
import WhatsAppIcon from './icons/WhatsApp.astro';
import { socialLinks } from '../data/social-links';

const contactInfo = [
  {
    title: 'Email',
    value: 'info@loducode.com',
    href: 'mailto:info@loducode.com',
    icon: 'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75',
  },
  {
    title: 'Teléfono',
    value: '+57 316 629 9222',
    href: 'tel:+573166299222',
    icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
  },
  {
    title: 'Dirección',
    value: 'Calle 19c # 19-20, Villavicencio',
    href: '#',
    icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
  },
];
---
<section id="contacto" class="py-20 lg:py-28 relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <!-- Gradient background accent -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-accent-cyan/5 to-transparent"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full bg-accent-purple/5 blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionHeading
        subtitle="Da el primer paso"
        title="Tu Proximo Proyecto Empieza Aqui"
        description="Cuentanos tu reto. En menos de 24 horas tendras una respuesta con ideas concretas para resolverlo."
      />
    </ScrollReveal>

    <!-- WhatsApp CTA -->
    <ScrollReveal delay="100ms" class="text-center mb-12">
      <a
        href={socialLinks.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-10 py-4 rounded-full bg-[#25d366] text-white font-bold text-lg shadow-lg shadow-[#25d366]/30 hover:shadow-[#25d366]/50 hover:scale-105 transition-all duration-300"
      >
        <WhatsAppIcon class="w-6 h-6" />
        Hablemos ahora por WhatsApp
      </a>
    </ScrollReveal>

    <!-- Contact info cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
      {contactInfo.map((info, i) => (
        <ScrollReveal delay={`${(i + 2) * 100}ms`}>
          <a href={info.href} class="block">
            <div class="glass glass-hover p-6 text-center h-full">
              <div class="w-12 h-12 mx-auto flex items-center justify-center rounded-xl bg-accent-cyan/10 text-accent-cyan mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={info.icon} />
                </svg>
              </div>
              <h3 class="text-sm font-semibold text-text-primary mb-1">{info.title}</h3>
              <p class="text-sm text-text-secondary">{info.value}</p>
            </div>
          </a>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
