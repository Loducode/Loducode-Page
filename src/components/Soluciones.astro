---
import SectionHeading from './SectionHeading.astro';
import ScrollReveal from './ScrollReveal.astro';
import { getSoluciones } from '../data/soluciones';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const soluciones = getSoluciones(lang);
---
<section id="soluciones" class="py-20 lg:py-28 bg-bg-secondary relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionHeading
        subtitle={t('solutions.subtitle')}
        title={t('solutions.title')}
        description={t('solutions.description')}
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {soluciones.map((sol, i) => (
        <ScrollReveal delay={`${i * 100}ms`}>
          <div id={sol.id} class="glass glass-hover p-8 lg:p-10 h-full flex flex-col group scroll-mt-24">
            <!-- Visual header: icon + mini illustration -->
            <div class="flex items-start justify-between mb-6">
              <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-r from-accent-cyan to-accent-purple rounded-xl blur-lg opacity-0 group-hover:opacity-30 transition-opacity duration-500"></div>
                <div class="relative w-16 h-16 flex items-center justify-center rounded-xl bg-gradient-to-br from-accent-cyan/10 to-accent-purple/10 border border-border-glass text-accent-cyan">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={sol.icon} />
                  </svg>
                </div>
              </div>
              <!-- Mini visual accent -->
              <div class="w-24 h-16 rounded-lg bg-gradient-to-br from-accent-cyan/5 to-accent-purple/5 border border-border-glass/30 overflow-hidden p-2 opacity-60 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                <div class="flex gap-0.5 mb-1">
                  <div class="h-1 w-1 rounded-full bg-accent-cyan/40"></div>
                  <div class="h-1 w-1 rounded-full bg-accent-purple/40"></div>
                  <div class="h-1 w-1 rounded-full bg-green-400/40"></div>
                </div>
                <div class="flex items-end gap-0.5 h-8">
                  <div class="flex-1 bg-accent-cyan/20 rounded-t" style={`height: ${30 + i * 15}%`}></div>
                  <div class="flex-1 bg-accent-cyan/30 rounded-t" style={`height: ${50 + i * 10}%`}></div>
                  <div class="flex-1 bg-accent-purple/20 rounded-t" style={`height: ${40 + i * 12}%`}></div>
                  <div class="flex-1 bg-accent-cyan/40 rounded-t" style={`height: ${70 - i * 8}%`}></div>
                  <div class="flex-1 bg-accent-purple/30 rounded-t" style={`height: ${60 + i * 5}%`}></div>
                </div>
              </div>
            </div>

            <!-- Content -->
            <h3 class="text-2xl font-bold text-text-primary mb-1">{sol.title}</h3>
            <p class="text-sm font-medium text-accent-cyan mb-4">{sol.tagline}</p>
            <p class="text-text-secondary leading-relaxed mb-6">{sol.description}</p>

            <!-- Service badges -->
            <div class="flex flex-wrap gap-2 mb-6">
              {sol.servicios.map((servicio) => (
                <span class="px-3 py-1 text-xs font-medium rounded-full border border-border-glass text-text-secondary/80">
                  {servicio}
                </span>
              ))}
            </div>

            <!-- CTA -->
            <div class="mt-auto">
              <a
                href={`https://api.whatsapp.com/send?phone=573166299222&text=${encodeURIComponent(sol.whatsappMsg)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-gradient-to-r from-accent-cyan to-accent-purple text-white text-sm font-semibold hover:scale-105 hover:shadow-[0_0_20px_rgba(56,189,248,0.3)] transition-all duration-300"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                {t('solutions.cta')}
              </a>
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
