---
import { socialLinks } from '../data/social-links';
import DashboardMockup from './illustrations/DashboardMockup.astro';
import PhoneMockup from './illustrations/PhoneMockup.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Animated gradient background -->
  <div
    class="absolute inset-0 -z-10"
    style="background: linear-gradient(135deg, #0a0a0a 0%, #0d1117 25%, #0a1a2e 50%, #091e33 75%, #0a0a0a 100%); background-size: 400% 400%; animation: gradient-shift 12s ease infinite;"
  ></div>

  <!-- Particle canvas -->
  <canvas id="hero-particles" class="absolute inset-0 -z-5 w-full h-full"></canvas>

  <!-- Morphing blobs -->
  <div class="absolute top-[15%] left-[10%] w-64 h-64 bg-accent-cyan/8 blur-2xl" style="animation: morph 8s ease-in-out infinite, float 7s ease-in-out infinite;"></div>
  <div class="absolute bottom-[15%] right-[10%] w-80 h-80 bg-accent-purple/8 blur-2xl" style="animation: morph 10s ease-in-out infinite reverse, float-slow 9s ease-in-out infinite;"></div>

  <!-- Orbiting elements -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] lg:w-[700px] lg:h-[700px] pointer-events-none">
    <!-- Orbit ring 1 -->
    <div class="absolute inset-0 rounded-full border border-border-glass/30 animate-[spin_40s_linear_infinite]"></div>
    <!-- Orbit dot 1 -->
    <div class="absolute top-1/2 left-1/2 w-3 h-3 -translate-x-1/2 -translate-y-1/2" style="--orbit-radius: 250px; animation: orbit 20s linear infinite;">
      <div class="w-3 h-3 rounded-full bg-accent-cyan shadow-[0_0_12px_rgba(56,189,248,0.8)]"></div>
    </div>
    <!-- Orbit ring 2 -->
    <div class="absolute inset-12 rounded-full border border-border-glass/20 animate-[spin_30s_linear_infinite_reverse]"></div>
    <!-- Orbit dot 2 -->
    <div class="absolute top-1/2 left-1/2 w-2.5 h-2.5 -translate-x-1/2 -translate-y-1/2" style="--orbit-radius: 180px; animation: orbit-reverse 15s linear infinite;">
      <div class="w-2.5 h-2.5 rounded-full bg-accent-purple shadow-[0_0_12px_rgba(12,139,192,0.8)]"></div>
    </div>
    <!-- Orbit ring 3 -->
    <div class="absolute inset-24 rounded-full border border-border-glass/10 animate-[spin_25s_linear_infinite]"></div>
    <!-- Orbit dot 3 -->
    <div class="absolute top-1/2 left-1/2 w-2 h-2 -translate-x-1/2 -translate-y-1/2" style="--orbit-radius: 110px; animation: orbit 12s linear infinite;">
      <div class="w-2 h-2 rounded-full bg-accent-cyan/70 shadow-[0_0_8px_rgba(56,189,248,0.6)]"></div>
    </div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 -z-4 opacity-[0.03]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>

  <!-- Glowing horizontal line -->
  <div class="absolute top-1/2 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/20 to-transparent" style="animation: scale-pulse 4s ease-in-out infinite;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 lg:pt-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
    <!-- Left: Text content -->
    <div class="text-center lg:text-left">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-sm text-text-secondary mb-8" style="animation: fade-in-down 0.6s ease-out both;">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-cyan opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-cyan"></span>
        </span>
        {t('hero.badge')}
      </div>

      <!-- Title with animated words -->
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight"
        style="animation: fade-in-up 0.8s ease-out 0.2s both;"
      >
        {t('hero.title.line1')}
        <br class="hidden sm:block" />
        <span class="gradient-text inline-block" style="animation: scale-pulse 3s ease-in-out infinite;">{t('hero.title.highlight')}</span>
        <br class="hidden sm:block" />
        {t('hero.title.line2')}
      </h1>

      <!-- Subtitle -->
      <div class="mt-6 max-w-2xl mx-auto" style="animation: fade-in-up 0.8s ease-out 0.4s both;">
        <p class="text-lg sm:text-xl text-text-secondary leading-relaxed">
          {t('hero.subtitle')}
        </p>
        <!-- Trust signal -->
        <p class="mt-4 text-sm text-text-secondary/60">
          {t('hero.trust')}
        </p>
      </div>

      <!-- CTAs -->
      <div
        class="mt-10 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4"
        style="animation: fade-in-up 0.8s ease-out 0.6s both;"
      >
        <a
          href={getLocalePath('/#contacto', lang)}
          class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-gradient-to-r from-accent-cyan to-accent-purple text-white font-semibold text-sm overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(56,189,248,0.4)]"
        >
          <span class="absolute inset-0 bg-gradient-to-r from-accent-purple to-accent-cyan opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
          <span class="relative">{t('hero.cta')}</span>
          <svg class="relative w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
        <a
          href={socialLinks.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 px-8 py-3.5 rounded-full glass glass-hover text-text-primary font-semibold text-sm"
        >
          <svg class="w-5 h-5 text-[#25d366] group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>

      <!-- Stats -->
      <div
        class="mt-10 flex items-center justify-center lg:justify-start gap-6 sm:gap-10"
        style="animation: fade-in-up 0.8s ease-out 0.8s both;"
      >
        <div class="text-center">
          <div class="text-2xl font-bold gradient-text">+50</div>
          <div class="text-xs text-text-secondary">{t('hero.stats.projects')}</div>
        </div>
        <div class="w-px h-8 bg-border-glass"></div>
        <div class="text-center">
          <div class="text-2xl font-bold gradient-text">+5</div>
          <div class="text-xs text-text-secondary">{t('hero.stats.years')}</div>
        </div>
        <div class="w-px h-8 bg-border-glass"></div>
        <div class="text-center">
          <div class="text-2xl font-bold gradient-text">+30</div>
          <div class="text-xs text-text-secondary">{t('hero.stats.clients')}</div>
        </div>
      </div>

    </div>

    <!-- Right: Mockup illustrations (desktop only) -->
    <div class="hidden lg:block relative" style="animation: fade-in-up 1s ease-out 0.5s both;">
      <DashboardMockup class="w-full max-w-md ml-auto" />
      <PhoneMockup class="absolute -bottom-8 -left-8" />
    </div>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 flex justify-center" style="animation: fade-in-up 1s ease-out 1s both;">
      <a href={getLocalePath('/#problemas', lang)} class="flex flex-col items-center gap-2 text-text-secondary hover:text-accent-cyan transition-colors group">
        <span class="text-xs uppercase tracking-widest">{t('hero.discover')}</span>
        <div class="w-6 h-10 rounded-full border-2 border-text-secondary/30 group-hover:border-accent-cyan/50 flex justify-center pt-2 transition-colors">
          <div class="w-1 h-2.5 rounded-full bg-text-secondary group-hover:bg-accent-cyan animate-bounce transition-colors"></div>
        </div>
      </a>
    </div>
  </div>
</section>


<script>
  // Particle network animation
  const canvas = document.getElementById('hero-particles') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let w = canvas.width = canvas.offsetWidth;
    let h = canvas.height = canvas.offsetHeight;
    const particles: { x: number; y: number; vx: number; vy: number; r: number; color: string }[] = [];
    const count = Math.min(60, Math.floor((w * h) / 15000));
    const maxDist = 150;

    for (let i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: Math.random() * 1.5 + 0.5,
        color: Math.random() > 0.5 ? 'rgba(56,189,248,' : 'rgba(12,139,192,',
      });
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = p.color + '0.6)';
        ctx.fill();

        for (let j = i + 1; j < particles.length; j++) {
          const p2 = particles[j];
          const dx = p.x - p2.x;
          const dy = p.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < maxDist) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(p2.x, p2.y);
            const alpha = (1 - dist / maxDist) * 0.15;
            ctx.strokeStyle = `rgba(56,189,248,${alpha})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }
    draw();

    window.addEventListener('resize', () => {
      w = canvas.width = canvas.offsetWidth;
      h = canvas.height = canvas.offsetHeight;
    });
  }
</script>
