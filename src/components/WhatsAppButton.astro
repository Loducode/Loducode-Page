---
import WhatsAppIcon from './icons/WhatsApp.astro';
import { socialLinks } from '../data/social-links';
---
<a
  href={socialLinks.whatsapp}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  class="fixed bottom-6 right-6 z-40 flex items-center justify-center w-14 h-14 rounded-full bg-[#25d366] text-white shadow-lg hover:scale-110 transition-transform duration-300"
  style="animation: glow-pulse 2s ease-in-out infinite;"
>
  <WhatsAppIcon class="w-7 h-7" />
</a>
