---
import SectionHeading from './SectionHeading.astro';
import ScrollReveal from './ScrollReveal.astro';
import { problemas } from '../data/problemas';
---
<section id="problemas" class="py-20 lg:py-28 relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionHeading
        subtitle="Esto te suena familiar?"
        title="Los Retos Que Frenan a Tu Empresa"
        description="Si tu empresa enfrenta alguno de estos problemas, tenemos la solucion"
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {problemas.map((problema, i) => (
        <ScrollReveal delay={`${i * 100}ms`}>
          <div class="glass glass-hover p-8 h-full flex flex-col group">
            <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-accent-cyan/10 text-accent-cyan mb-5">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={problema.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-3">{problema.title}</h3>
            <p class="text-text-secondary leading-relaxed flex-1">{problema.description}</p>
            <a
              href={problema.solucion}
              class="inline-flex items-center gap-2 mt-5 text-sm font-medium text-accent-cyan group-hover:gap-3 transition-all duration-300"
            >
              Ver como lo resolvemos
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
