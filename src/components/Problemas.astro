---
import SectionHeading from './SectionHeading.astro';
import ScrollReveal from './ScrollReveal.astro';
import { problemas } from '../data/problemas';
---
<section id="problemas" class="py-20 lg:py-28 relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionHeading
        subtitle="¿Esto te suena familiar?"
        title="Los Retos Que Frenan a Tu Empresa"
        description="Si tu empresa enfrenta alguno de estos problemas, tenemos la solución"
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {problemas.map((problema, i) => (
        <ScrollReveal delay={`${i * 100}ms`}>
          <div class="glass glass-hover p-8 h-full flex flex-col group">
            <div class="flex items-start justify-between mb-5">
              <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-red-500/10 text-red-400 border border-red-500/20">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={problema.icon} />
                </svg>
              </div>
              <!-- Problem visual indicator -->
              <div class="w-28 h-14 rounded-lg bg-red-500/5 border border-red-500/10 overflow-hidden p-2 opacity-50 group-hover:opacity-80 transition-opacity" aria-hidden="true">
                {i === 0 && (
                  <div class="flex items-end gap-1 h-full">
                    <div class="flex-1 bg-red-400/15 rounded-t animate-pulse" style="height: 90%"></div>
                    <div class="flex-1 bg-red-400/20 rounded-t" style="height: 70%"></div>
                    <div class="flex-1 bg-red-400/15 rounded-t animate-pulse" style="height: 85%; animation-delay: 0.5s"></div>
                    <div class="flex-1 bg-red-400/20 rounded-t" style="height: 60%"></div>
                    <div class="flex-1 bg-red-400/10 rounded-t" style="height: 45%"></div>
                  </div>
                )}
                {i === 1 && (
                  <div class="flex items-end gap-1 h-full">
                    <div class="flex-1 bg-green-400/25 rounded-t" style="height: 90%"></div>
                    <div class="flex-1 bg-green-400/20 rounded-t" style="height: 75%"></div>
                    <div class="w-px h-full bg-border-glass/30"></div>
                    <div class="flex-1 bg-red-400/20 rounded-t" style="height: 30%"></div>
                    <div class="flex-1 bg-red-400/15 rounded-t" style="height: 20%"></div>
                  </div>
                )}
                {i === 2 && (
                  <div class="space-y-1 h-full flex flex-col justify-center">
                    <div class="h-1.5 w-full rounded bg-white/5"></div>
                    <div class="h-1.5 w-3/4 rounded bg-white/5"></div>
                    <div class="h-1.5 w-full rounded bg-white/5"></div>
                    <div class="h-1.5 w-1/2 rounded bg-red-400/15"></div>
                  </div>
                )}
                {i === 3 && (
                  <div class="flex items-center justify-center h-full gap-1.5">
                    <div class="w-5 h-5 rounded border border-red-400/20 flex items-center justify-center">
                      <div class="w-2 h-2 rounded-full bg-red-400/40 animate-pulse"></div>
                    </div>
                    <div class="space-y-1">
                      <div class="h-1 w-10 rounded bg-red-400/15"></div>
                      <div class="h-1 w-7 rounded bg-red-400/10"></div>
                    </div>
                  </div>
                )}
              </div>
            </div>
            <p class="text-xl font-bold text-text-primary mb-3">{problema.title}</p>
            <p class="text-text-secondary leading-relaxed flex-1">{problema.description}</p>
            <a
              href={problema.solucion}
              class="inline-flex items-center gap-2 mt-5 text-sm font-medium text-accent-cyan group-hover:gap-3 transition-all duration-300"
            >
              Ver como lo resolvemos
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
