---
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils';

interface Props {
  title: string;
  date: Date;
  author: string;
  image: string;
  excerpt: string;
  category: string;
  slug: string;
  delay?: string;
}

const { title, date, author, image, excerpt, category, slug, delay = '0ms' } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const dateLocale = lang === 'en' ? 'en-US' : 'es-CO';
const readMore = lang === 'en' ? 'Read more' : 'Leer más';

const formattedDate = new Intl.DateTimeFormat(dateLocale, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);
---
<div class="scroll-reveal" style={`transition-delay: ${delay}`}>
  <a href={getLocalePath(`/blog/${slug}/`, lang)} class="group block h-full">
    <div class="glass glass-hover h-full overflow-hidden flex flex-col">
      <!-- Dynamic blog illustration -->
      <div class="relative h-48 bg-gradient-to-br from-accent-cyan/5 to-accent-purple/5 overflow-hidden group-hover:from-accent-cyan/10 group-hover:to-accent-purple/10 transition-all duration-500">
        <div class="absolute inset-0 flex items-center justify-center p-6">
          {category.toLowerCase().includes('ia') || category.toLowerCase().includes('inteligencia') || category.toLowerCase().includes('ai') ? (
            <!-- AI / Neural network illustration -->
            <div class="relative group-hover:scale-105 transition-transform duration-500">
              <div class="flex items-center gap-4">
                <div class="space-y-3">
                  <div class="w-4 h-4 rounded-full bg-accent-cyan/30 shadow-[0_0_8px_rgba(56,189,248,0.3)]"></div>
                  <div class="w-4 h-4 rounded-full bg-accent-purple/30 shadow-[0_0_8px_rgba(12,139,192,0.3)]"></div>
                  <div class="w-4 h-4 rounded-full bg-accent-cyan/30 shadow-[0_0_8px_rgba(56,189,248,0.3)]"></div>
                </div>
                <div class="space-y-2">
                  <div class="w-16 border-t border-dashed border-accent-cyan/20"></div>
                  <div class="w-12 border-t border-dashed border-accent-purple/20"></div>
                  <div class="w-14 border-t border-dashed border-accent-cyan/20"></div>
                </div>
                <div class="space-y-5">
                  <div class="w-5 h-5 rounded-full bg-accent-purple/40 shadow-[0_0_10px_rgba(12,139,192,0.4)]"></div>
                  <div class="w-5 h-5 rounded-full bg-accent-cyan/40 shadow-[0_0_10px_rgba(56,189,248,0.4)]"></div>
                </div>
                <div class="space-y-2">
                  <div class="w-10 border-t border-dashed border-accent-purple/20"></div>
                  <div class="w-12 border-t border-dashed border-accent-cyan/20"></div>
                </div>
                <div class="w-6 h-6 rounded-full bg-green-500/40 shadow-[0_0_12px_rgba(34,197,94,0.4)]"></div>
              </div>
            </div>
          ) : category.toLowerCase().includes('móvil') || category.toLowerCase().includes('movil') || category.toLowerCase().includes('mobile') ? (
            <!-- Mobile illustration -->
            <div class="w-20 h-36 rounded-2xl border border-border-glass/40 bg-bg-primary/60 p-1.5 group-hover:scale-105 transition-transform duration-500">
              <div class="w-6 h-2 mx-auto rounded-full bg-bg-primary border border-border-glass/30 mb-1"></div>
              <div class="rounded-xl bg-bg-secondary h-full overflow-hidden p-1.5 space-y-1">
                <div class="h-6 rounded bg-accent-cyan/10"></div>
                <div class="h-1 w-3/4 rounded bg-white/8"></div>
                <div class="h-1 w-1/2 rounded bg-white/5"></div>
                <div class="grid grid-cols-2 gap-1 mt-1"><div class="h-4 rounded bg-accent-purple/10"></div><div class="h-4 rounded bg-accent-cyan/10"></div></div>
              </div>
            </div>
          ) : (
            <!-- Default: code/development illustration -->
            <div class="w-48 rounded-lg border border-border-glass/30 bg-bg-primary/50 overflow-hidden group-hover:scale-105 transition-transform duration-500">
              <div class="flex gap-1 px-2.5 py-1.5 bg-white/[0.02] border-b border-border-glass/20"><div class="w-1.5 h-1.5 rounded-full bg-red-400/40"></div><div class="w-1.5 h-1.5 rounded-full bg-yellow-400/40"></div><div class="w-1.5 h-1.5 rounded-full bg-green-400/40"></div></div>
              <div class="p-3 space-y-1.5 font-mono">
                <div class="flex gap-1.5"><div class="h-1.5 w-6 rounded bg-accent-purple/30"></div><div class="h-1.5 w-12 rounded bg-accent-cyan/20"></div></div>
                <div class="flex gap-1.5 pl-3"><div class="h-1.5 w-8 rounded bg-green-500/20"></div><div class="h-1.5 w-14 rounded bg-white/8"></div></div>
                <div class="flex gap-1.5 pl-3"><div class="h-1.5 w-10 rounded bg-accent-cyan/20"></div><div class="h-1.5 w-6 rounded bg-yellow-400/15"></div></div>
                <div class="flex gap-1.5 pl-6"><div class="h-1.5 w-12 rounded bg-white/6"></div><div class="h-1.5 w-4 rounded bg-accent-purple/20"></div></div>
                <div class="flex gap-1.5"><div class="h-1.5 w-4 rounded bg-accent-purple/30"></div></div>
                <div class="h-1.5 w-0 rounded bg-accent-cyan/40 animate-pulse" style="animation: typewriter 2s steps(20) infinite; max-width: 60%"></div>
              </div>
            </div>
          )}
        </div>
        <span class="absolute top-3 left-3 px-3 py-1 text-xs font-semibold rounded-full bg-accent-cyan/20 text-accent-cyan backdrop-blur-sm">
          {category}
        </span>
      </div>

      <!-- Content -->
      <div class="p-6 flex flex-col flex-1">
        <div class="flex items-center gap-3 text-xs text-text-secondary mb-3">
          <span>{formattedDate}</span>
          <span class="w-1 h-1 rounded-full bg-text-secondary"></span>
          <span>{author}</span>
        </div>
        <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent-cyan transition-colors duration-300 mb-2">
          {title}
        </h3>
        <p class="text-sm text-text-secondary leading-relaxed flex-1">{excerpt}</p>
        <div class="mt-4 flex items-center gap-2 text-sm font-medium text-accent-cyan group-hover:gap-3 transition-all duration-300">
          {readMore}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </div>
      </div>
    </div>
  </a>
</div>
