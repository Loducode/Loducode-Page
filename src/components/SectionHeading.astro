---
interface Props {
  subtitle?: string;
  title: string;
  description?: string;
}

const { subtitle, title, description } = Astro.props;
---
<div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
  {subtitle && (
    <span class="inline-block text-sm font-semibold uppercase tracking-widest text-accent-cyan mb-3">
      {subtitle}
    </span>
  )}
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold gradient-text leading-tight">
    {title}
  </h2>
  {description && (
    <p class="mt-4 text-text-secondary text-lg leading-relaxed">
      {description}
    </p>
  )}
</div>
