---
interface Props { class?: string }
const { class: className = '' } = Astro.props;
---
<!-- Floating phone mockup -->
<div class={`relative ${className}`} style="animation: float-slow 7s ease-in-out infinite;">
  <div class="w-44 mx-auto">
    <!-- Phone frame -->
    <div class="rounded-3xl border-2 border-border-glass/40 bg-bg-primary/80 backdrop-blur p-2 shadow-2xl shadow-accent-purple/10">
      <!-- Notch -->
      <div class="flex justify-center mb-2">
        <div class="w-16 h-4 rounded-full bg-bg-primary border border-border-glass/30"></div>
      </div>
      <!-- Screen -->
      <div class="rounded-2xl bg-bg-secondary overflow-hidden">
        <!-- Status bar -->
        <div class="flex items-center justify-between px-3 py-1.5">
          <div class="h-1.5 w-8 rounded bg-white/20"></div>
          <div class="flex gap-1">
            <div class="h-1.5 w-3 rounded bg-white/20"></div>
            <div class="h-1.5 w-3 rounded bg-white/20"></div>
          </div>
        </div>
        <!-- App header -->
        <div class="px-3 py-2 flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-accent-cyan/30"></div>
          <div class="h-2 w-16 rounded bg-white/15"></div>
        </div>
        <!-- Content -->
        <div class="px-3 py-2 space-y-2">
          <!-- Card -->
          <div class="rounded-lg bg-accent-cyan/10 p-2.5">
            <div class="h-2 w-20 rounded bg-accent-cyan/40 mb-1.5"></div>
            <div class="h-5 w-16 rounded bg-accent-cyan/60"></div>
          </div>
          <!-- List items -->
          <div class="space-y-1.5">
            <div class="flex items-center gap-2 rounded-lg bg-white/[0.03] p-2">
              <div class="w-5 h-5 rounded bg-accent-purple/20"></div>
              <div class="flex-1">
                <div class="h-1.5 w-full rounded bg-white/10"></div>
                <div class="h-1.5 w-3/4 rounded bg-white/5 mt-1"></div>
              </div>
            </div>
            <div class="flex items-center gap-2 rounded-lg bg-white/[0.03] p-2">
              <div class="w-5 h-5 rounded bg-green-500/20"></div>
              <div class="flex-1">
                <div class="h-1.5 w-full rounded bg-white/10"></div>
                <div class="h-1.5 w-1/2 rounded bg-white/5 mt-1"></div>
              </div>
            </div>
            <div class="flex items-center gap-2 rounded-lg bg-white/[0.03] p-2">
              <div class="w-5 h-5 rounded bg-accent-cyan/20"></div>
              <div class="flex-1">
                <div class="h-1.5 w-full rounded bg-white/10"></div>
                <div class="h-1.5 w-2/3 rounded bg-white/5 mt-1"></div>
              </div>
            </div>
          </div>
        </div>
        <!-- Bottom nav -->
        <div class="flex justify-around px-3 py-2.5 border-t border-border-glass/20 mt-2">
          <div class="w-4 h-4 rounded bg-accent-cyan/30"></div>
          <div class="w-4 h-4 rounded bg-white/10"></div>
          <div class="w-4 h-4 rounded bg-white/10"></div>
          <div class="w-4 h-4 rounded bg-white/10"></div>
        </div>
      </div>
    </div>
  </div>
</div>
