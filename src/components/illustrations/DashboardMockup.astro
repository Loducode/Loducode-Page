---
interface Props { class?: string }
const { class: className = '' } = Astro.props;
---
<!-- Floating dashboard mockup illustration -->
<div class={`relative ${className}`} style="animation: float 6s ease-in-out infinite;">
  <!-- Browser frame -->
  <div class="glass rounded-2xl overflow-hidden shadow-2xl shadow-accent-cyan/10 border border-border-glass/50">
    <!-- Browser bar -->
    <div class="flex items-center gap-2 px-4 py-2.5 bg-white/[0.03] border-b border-border-glass/50">
      <div class="flex gap-1.5">
        <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-green-400/60"></div>
      </div>
      <div class="flex-1 mx-4 h-5 rounded-full bg-white/[0.05] flex items-center px-3">
        <span class="text-[10px] text-text-secondary/40">app.loducode.com</span>
      </div>
    </div>
    <!-- Dashboard content -->
    <div class="p-4 space-y-3">
      <!-- Stats row -->
      <div class="grid grid-cols-3 gap-2">
        <div class="rounded-lg bg-accent-cyan/10 p-3">
          <div class="h-2 w-8 rounded bg-accent-cyan/40 mb-2"></div>
          <div class="h-4 w-12 rounded bg-accent-cyan/60"></div>
        </div>
        <div class="rounded-lg bg-accent-purple/10 p-3">
          <div class="h-2 w-10 rounded bg-accent-purple/40 mb-2"></div>
          <div class="h-4 w-14 rounded bg-accent-purple/60"></div>
        </div>
        <div class="rounded-lg bg-green-500/10 p-3">
          <div class="h-2 w-6 rounded bg-green-500/40 mb-2"></div>
          <div class="h-4 w-10 rounded bg-green-500/60"></div>
        </div>
      </div>
      <!-- Chart area -->
      <div class="rounded-lg bg-white/[0.03] p-3">
        <div class="flex items-end gap-1.5 h-20">
          <div class="flex-1 bg-accent-cyan/20 rounded-t" style="height: 40%"></div>
          <div class="flex-1 bg-accent-cyan/30 rounded-t" style="height: 60%"></div>
          <div class="flex-1 bg-accent-cyan/40 rounded-t" style="height: 45%"></div>
          <div class="flex-1 bg-accent-cyan/50 rounded-t" style="height: 80%"></div>
          <div class="flex-1 bg-accent-cyan/40 rounded-t" style="height: 55%"></div>
          <div class="flex-1 bg-accent-cyan/60 rounded-t" style="height: 90%"></div>
          <div class="flex-1 bg-accent-cyan/50 rounded-t" style="height: 70%"></div>
        </div>
      </div>
      <!-- Table rows -->
      <div class="space-y-1.5">
        <div class="flex gap-2 items-center">
          <div class="w-6 h-6 rounded-full bg-accent-purple/20"></div>
          <div class="h-2 flex-1 rounded bg-white/[0.06]"></div>
          <div class="h-2 w-12 rounded bg-accent-cyan/30"></div>
        </div>
        <div class="flex gap-2 items-center">
          <div class="w-6 h-6 rounded-full bg-accent-cyan/20"></div>
          <div class="h-2 flex-1 rounded bg-white/[0.06]"></div>
          <div class="h-2 w-16 rounded bg-green-500/30"></div>
        </div>
        <div class="flex gap-2 items-center">
          <div class="w-6 h-6 rounded-full bg-green-500/20"></div>
          <div class="h-2 flex-1 rounded bg-white/[0.06]"></div>
          <div class="h-2 w-10 rounded bg-accent-purple/30"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Floating notification card -->
  <div class="absolute -top-4 -right-4 glass rounded-xl p-3 shadow-lg shadow-accent-cyan/10 border border-border-glass/50" style="animation: float-slow 4s ease-in-out infinite;">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center">
        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
      </div>
      <div>
        <div class="h-2 w-16 rounded bg-white/20 mb-1"></div>
        <div class="h-1.5 w-10 rounded bg-green-400/40"></div>
      </div>
    </div>
  </div>

  <!-- Floating chat bubble -->
  <div class="absolute -bottom-3 -left-6 glass rounded-xl p-3 shadow-lg shadow-accent-purple/10 border border-border-glass/50" style="animation: float 5s ease-in-out 1s infinite;">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-full bg-accent-cyan/20 flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-accent-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
      </div>
      <div>
        <div class="h-1.5 w-20 rounded bg-white/15"></div>
        <div class="h-1.5 w-14 rounded bg-white/10 mt-1"></div>
      </div>
    </div>
  </div>
</div>
