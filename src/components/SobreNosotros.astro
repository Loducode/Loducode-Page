---
import ScrollReveal from './ScrollReveal.astro';

const capabilities = [
  { title: 'Inteligencia Artificial', icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z' },
  { title: 'Blockchain & Web3', icon: 'M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25' },
  { title: 'Plataformas web', icon: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418' },
  { title: 'Aplicaciones móviles', icon: 'M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3' },
  { title: 'Sistemas de Información', icon: 'M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125' },
  { title: 'Sistemas de Gestión', icon: 'M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75' },
];
---
<section id="nosotros" class="py-20 lg:py-28 bg-bg-secondary relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: Text -->
      <ScrollReveal>
        <div>
          <span class="inline-block text-sm font-semibold uppercase tracking-widest text-accent-cyan mb-3">
            Por que elegirnos
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
            No solo escribimos codigo.
            <span class="gradient-text"> Construimos</span> la tecnologia que impulsa tu crecimiento.
          </h2>
          <p class="mt-6 text-text-secondary text-lg leading-relaxed">
            Desde Villavicencio, Colombia, hemos ayudado a empresas del sector privado y publico a
            escalar sus operaciones con
            <strong class="text-text-primary">Inteligencia Artificial</strong>,
            <strong class="text-text-primary">Blockchain</strong> y software a la medida.
            No entregamos proyectos: entregamos ventajas competitivas.
          </p>

          <!-- Stats -->
          <div class="mt-8 grid grid-cols-3 gap-4">
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-bold gradient-text">+50</div>
              <div class="text-xs text-text-secondary mt-1">Proyectos entregados</div>
            </div>
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-bold gradient-text">+5</div>
              <div class="text-xs text-text-secondary mt-1">Anos de experiencia</div>
            </div>
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-bold gradient-text">+30</div>
              <div class="text-xs text-text-secondary mt-1">Clientes satisfechos</div>
            </div>
          </div>
        </div>
      </ScrollReveal>

      <!-- Right: Capabilities -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-2 gap-4">
        {capabilities.map((cap, i) => (
          <ScrollReveal delay={`${i * 100}ms`}>
            <div class="glass glass-hover p-6 flex flex-col items-center text-center gap-3">
              <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-accent-cyan/10 text-accent-cyan">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={cap.icon} />
                </svg>
              </div>
              <h3 class="text-sm font-semibold text-text-primary">{cap.title}</h3>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </div>
</section>
