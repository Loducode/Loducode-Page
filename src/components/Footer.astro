---
import SocialLinks from './SocialLinks.astro';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/#problemas', label: 'Retos' },
  { href: '/#soluciones', label: 'Soluciones' },
  { href: '/#casos', label: 'Casos de Exito' },
  { href: '/#proceso', label: 'Proceso' },
  { href: '/#contacto', label: 'Contacto' },
];
---
<footer class="border-t border-border-glass bg-bg-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">
      <!-- Logo & Description -->
      <div>
        <img src="/images/logo-white.png" alt="Loducode S.A.S." class="h-10 w-auto" />
        <p class="mt-4 text-text-secondary text-sm leading-relaxed">
          Software a la medida, Inteligencia Artificial y Blockchain para empresas que
          quieren escalar. Transformamos ideas en productos digitales que generan resultados.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Navegación</h4>
        <ul class="space-y-2">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-text-secondary hover:text-accent-cyan transition-colors duration-300">
                {label}
              </a>
            </li>
          ))}
        </ul>
        <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4 mt-6">Recursos</h4>
        <ul class="space-y-2">
          <li>
            <a href="/blog/" class="text-sm text-text-secondary hover:text-accent-cyan transition-colors duration-300">Blog</a>
          </li>
          <li>
            <a href="/projects/" class="text-sm text-text-secondary hover:text-accent-cyan transition-colors duration-300">Portafolio</a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">Contacto</h4>
        <ul class="space-y-3 text-sm text-text-secondary">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-accent-cyan flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            Calle 19c # 19-20, Villavicencio
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-accent-cyan flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            <a href="mailto:info@loducode.com" class="hover:text-accent-cyan transition-colors">info@loducode.com</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-accent-cyan flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            <a href="tel:+573166299222" class="hover:text-accent-cyan transition-colors">+57 316 629 9222</a>
          </li>
        </ul>
        <div class="mt-6">
          <SocialLinks iconClass="w-4 h-4" />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-border-glass">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-text-secondary">
      <span>&copy; {new Date().getFullYear()} Loducode S.A.S. Todos los derechos reservados.</span>
      <span>Villavicencio, Meta - Colombia</span>
    </div>
  </div>
</footer>
