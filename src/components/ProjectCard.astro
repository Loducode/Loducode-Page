---
interface Props {
  title: string;
  date: Date;
  image: string;
  category: string;
  description: string;
  slug: string;
  delay?: string;
}

const { title, date, image, category, description, slug, delay = '0ms' } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('es-CO', {
  year: 'numeric',
  month: 'short',
}).format(date);
---
<div class="scroll-reveal" style={`transition-delay: ${delay}`}>
  <a href={`/projects/${slug}/`} class="group block h-full">
    <div class="glass glass-hover h-full overflow-hidden flex flex-col">
      <!-- Dynamic illustration -->
      <div class="relative h-48 bg-gradient-to-br from-accent-purple/5 to-accent-cyan/5 overflow-hidden group-hover:from-accent-purple/10 group-hover:to-accent-cyan/10 transition-all duration-500">
        <!-- Abstract mockup based on category -->
        <div class="absolute inset-0 flex items-center justify-center p-6">
          {category.toLowerCase().includes('app') || category.toLowerCase().includes('movil') ? (
            <!-- Phone mockup -->
            <div class="w-24 h-40 rounded-2xl border border-border-glass/40 bg-bg-primary/60 p-1.5 group-hover:scale-105 transition-transform duration-500">
              <div class="w-8 h-2.5 mx-auto rounded-full bg-bg-primary border border-border-glass/30 mb-1"></div>
              <div class="rounded-xl bg-bg-secondary h-full overflow-hidden p-2 space-y-1.5">
                <div class="flex gap-1"><div class="w-3 h-3 rounded-full bg-accent-cyan/25"></div><div class="h-1.5 flex-1 rounded bg-white/8 self-center"></div></div>
                <div class="rounded bg-accent-cyan/10 p-1.5"><div class="h-1.5 w-10 rounded bg-accent-cyan/30 mb-1"></div><div class="h-2.5 w-8 rounded bg-accent-cyan/40"></div></div>
                <div class="space-y-1"><div class="flex gap-1 items-center"><div class="w-2.5 h-2.5 rounded bg-accent-purple/15"></div><div class="h-1 flex-1 rounded bg-white/5"></div></div><div class="flex gap-1 items-center"><div class="w-2.5 h-2.5 rounded bg-green-500/15"></div><div class="h-1 flex-1 rounded bg-white/5"></div></div><div class="flex gap-1 items-center"><div class="w-2.5 h-2.5 rounded bg-accent-cyan/15"></div><div class="h-1 flex-1 rounded bg-white/5"></div></div></div>
              </div>
            </div>
          ) : category.toLowerCase().includes('chatbot') || category.toLowerCase().includes('ia') ? (
            <!-- Chat/AI mockup -->
            <div class="w-44 space-y-2 group-hover:scale-105 transition-transform duration-500">
              <div class="flex justify-end"><div class="rounded-xl rounded-br-sm bg-accent-cyan/15 px-3 py-2 max-w-[75%]"><div class="h-1.5 w-16 rounded bg-white/15 mb-1"></div><div class="h-1.5 w-10 rounded bg-white/10"></div></div></div>
              <div class="flex justify-start"><div class="rounded-xl rounded-bl-sm bg-white/[0.05] px-3 py-2 max-w-[80%]"><div class="h-1.5 w-20 rounded bg-white/10 mb-1"></div><div class="h-1.5 w-14 rounded bg-white/8 mb-1"></div><div class="h-1.5 w-8 rounded bg-accent-cyan/20"></div></div></div>
              <div class="flex justify-start"><div class="rounded-xl rounded-bl-sm bg-white/[0.05] px-3 py-2"><div class="flex gap-1"><div class="w-1.5 h-1.5 rounded-full bg-text-secondary/30 animate-bounce"></div><div class="w-1.5 h-1.5 rounded-full bg-text-secondary/30 animate-bounce" style="animation-delay:150ms"></div><div class="w-1.5 h-1.5 rounded-full bg-text-secondary/30 animate-bounce" style="animation-delay:300ms"></div></div></div></div>
            </div>
          ) : category.toLowerCase().includes('blockchain') ? (
            <!-- Blockchain mockup -->
            <div class="flex items-center gap-3 group-hover:scale-105 transition-transform duration-500">
              <div class="w-12 h-12 rounded-xl border border-accent-purple/30 bg-accent-purple/10 flex items-center justify-center"><div class="w-5 h-5 rounded border border-accent-purple/40"></div></div>
              <div class="w-8 border-t border-dashed border-accent-purple/30"></div>
              <div class="w-12 h-12 rounded-xl border border-accent-cyan/30 bg-accent-cyan/10 flex items-center justify-center"><div class="w-5 h-5 rounded border border-accent-cyan/40"></div></div>
              <div class="w-8 border-t border-dashed border-accent-cyan/30"></div>
              <div class="w-12 h-12 rounded-xl border border-green-500/30 bg-green-500/10 flex items-center justify-center"><div class="w-5 h-5 rounded border border-green-500/40"></div></div>
            </div>
          ) : category.toLowerCase().includes('marketplace') ? (
            <!-- Marketplace grid mockup -->
            <div class="grid grid-cols-3 gap-2 w-44 group-hover:scale-105 transition-transform duration-500">
              <div class="rounded-lg bg-white/[0.04] p-2 space-y-1"><div class="h-8 rounded bg-accent-cyan/10"></div><div class="h-1.5 w-full rounded bg-white/8"></div><div class="h-1.5 w-2/3 rounded bg-accent-cyan/20"></div></div>
              <div class="rounded-lg bg-white/[0.04] p-2 space-y-1"><div class="h-8 rounded bg-accent-purple/10"></div><div class="h-1.5 w-full rounded bg-white/8"></div><div class="h-1.5 w-3/4 rounded bg-accent-purple/20"></div></div>
              <div class="rounded-lg bg-white/[0.04] p-2 space-y-1"><div class="h-8 rounded bg-green-500/10"></div><div class="h-1.5 w-full rounded bg-white/8"></div><div class="h-1.5 w-1/2 rounded bg-green-500/20"></div></div>
              <div class="rounded-lg bg-white/[0.04] p-2 space-y-1"><div class="h-8 rounded bg-accent-purple/10"></div><div class="h-1.5 w-full rounded bg-white/8"></div><div class="h-1.5 w-2/3 rounded bg-accent-purple/20"></div></div>
              <div class="rounded-lg bg-white/[0.04] p-2 space-y-1"><div class="h-8 rounded bg-accent-cyan/10"></div><div class="h-1.5 w-full rounded bg-white/8"></div><div class="h-1.5 w-3/4 rounded bg-accent-cyan/20"></div></div>
              <div class="rounded-lg bg-white/[0.04] p-2 space-y-1"><div class="h-8 rounded bg-green-500/10"></div><div class="h-1.5 w-full rounded bg-white/8"></div><div class="h-1.5 w-1/2 rounded bg-green-500/20"></div></div>
            </div>
          ) : (
            <!-- Default: dashboard mockup -->
            <div class="w-48 rounded-xl border border-border-glass/30 bg-bg-primary/50 overflow-hidden group-hover:scale-105 transition-transform duration-500">
              <div class="flex gap-1 px-2.5 py-1.5 bg-white/[0.02] border-b border-border-glass/20"><div class="w-1.5 h-1.5 rounded-full bg-red-400/40"></div><div class="w-1.5 h-1.5 rounded-full bg-yellow-400/40"></div><div class="w-1.5 h-1.5 rounded-full bg-green-400/40"></div></div>
              <div class="p-3 space-y-2">
                <div class="grid grid-cols-3 gap-1.5"><div class="rounded bg-accent-cyan/10 p-1.5"><div class="h-1 w-5 rounded bg-accent-cyan/30 mb-0.5"></div><div class="h-2 w-7 rounded bg-accent-cyan/40"></div></div><div class="rounded bg-accent-purple/10 p-1.5"><div class="h-1 w-4 rounded bg-accent-purple/30 mb-0.5"></div><div class="h-2 w-6 rounded bg-accent-purple/40"></div></div><div class="rounded bg-green-500/10 p-1.5"><div class="h-1 w-5 rounded bg-green-500/30 mb-0.5"></div><div class="h-2 w-5 rounded bg-green-500/40"></div></div></div>
                <div class="flex items-end gap-0.5 h-10"><div class="flex-1 bg-accent-cyan/15 rounded-t" style="height:40%"></div><div class="flex-1 bg-accent-cyan/25 rounded-t" style="height:65%"></div><div class="flex-1 bg-accent-cyan/20 rounded-t" style="height:50%"></div><div class="flex-1 bg-accent-cyan/35 rounded-t" style="height:85%"></div><div class="flex-1 bg-accent-cyan/25 rounded-t" style="height:60%"></div></div>
              </div>
            </div>
          )}
        </div>
        <!-- Badges -->
        <span class="absolute top-3 left-3 px-3 py-1 text-xs font-semibold rounded-full bg-accent-purple/20 text-accent-purple backdrop-blur-sm">
          {category}
        </span>
        <span class="absolute top-3 right-3 px-3 py-1 text-xs rounded-full bg-bg-primary/50 text-text-secondary backdrop-blur-sm">
          {formattedDate}
        </span>
      </div>

      <!-- Content -->
      <div class="p-6 flex flex-col flex-1">
        <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent-purple transition-colors duration-300 mb-2">
          {title}
        </h3>
        <p class="text-sm text-text-secondary leading-relaxed flex-1">{description}</p>
        <div class="mt-4 flex items-center gap-2 text-sm font-medium text-accent-purple group-hover:gap-3 transition-all duration-300">
          Ver proyecto
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </div>
      </div>
    </div>
  </a>
</div>
