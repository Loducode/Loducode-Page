---
import ScrollReveal from './ScrollReveal.astro';
import SectionHeading from './SectionHeading.astro';
import { testimonials } from '../data/testimonials';
---
<section id="testimonios" class="py-20 lg:py-28 bg-bg-secondary relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <!-- Decorative -->
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-72 h-72 rounded-full bg-accent-cyan/5 blur-3xl"></div>
  <div class="absolute top-1/2 right-0 -translate-y-1/2 w-72 h-72 rounded-full bg-accent-purple/5 blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionHeading
        subtitle="Confianza comprobada"
        title="Ellos Ya Transformaron Su Negocio Con Nosotros"
      />
    </ScrollReveal>

    <!-- Scroll-snap carousel -->
    <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-4 -mx-4 px-4 scrollbar-hide">
      {testimonials.map((testimonial, i) => (
        <ScrollReveal delay={`${i * 150}ms`} class="min-w-[320px] sm:min-w-[400px] lg:min-w-[500px] snap-center flex-shrink-0">
          <div class="glass p-8 h-full flex flex-col">
            <!-- Quote icon -->
            <svg class="w-10 h-10 text-accent-cyan/30 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10H0z"/></svg>

            <p class="text-text-primary text-lg leading-relaxed italic flex-1">
              "{testimonial.text}"
            </p>

            <div class="mt-6 flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-accent-cyan to-accent-purple flex items-center justify-center text-white font-bold text-lg">
                {testimonial.author.charAt(0)}
              </div>
              <div>
                <div class="font-semibold text-text-primary">{testimonial.author}</div>
                <div class="text-sm text-text-secondary">{testimonial.role}</div>
              </div>
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
