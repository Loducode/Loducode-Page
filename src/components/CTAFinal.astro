---
import ScrollReveal from './ScrollReveal.astro';
import WhatsAppIcon from './icons/WhatsApp.astro';
import { socialLinks } from '../data/social-links';
---
<section id="contacto" class="py-20 lg:py-28 relative overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <!-- Gradient background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-accent-cyan/5 to-bg-primary"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent-cyan/5 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full bg-accent-purple/5 blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <ScrollReveal>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-6">
        Listo para
        <span class="gradient-text"> transformar </span>
        tu negocio?
      </h2>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
        Cuentanos tu reto. En menos de 24 horas tendras una respuesta con ideas concretas para resolverlo. Sin compromiso, sin letra pequena.
      </p>
    </ScrollReveal>

    <!-- Main CTA -->
    <ScrollReveal delay="100ms">
      <a
        href={socialLinks.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-10 py-4 rounded-full bg-[#25d366] text-white font-bold text-lg shadow-lg shadow-[#25d366]/30 hover:shadow-[#25d366]/50 hover:scale-105 transition-all duration-300"
      >
        <WhatsAppIcon class="w-6 h-6" />
        Hablemos ahora por WhatsApp
      </a>
    </ScrollReveal>

    <!-- Secondary CTA -->
    <ScrollReveal delay="200ms">
      <p class="mt-6 text-text-secondary">
        O escribenos a
        <a href="mailto:info@loducode.com" class="text-accent-cyan hover:underline font-medium">info@loducode.com</a>
      </p>
    </ScrollReveal>

    <!-- Stats -->
    <ScrollReveal delay="300ms">
      <div class="mt-12 grid grid-cols-3 gap-6 max-w-lg mx-auto">
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold gradient-text">+50</div>
          <div class="text-xs text-text-secondary mt-1">Proyectos entregados</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold gradient-text">+5</div>
          <div class="text-xs text-text-secondary mt-1">Anos de experiencia</div>
        </div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold gradient-text">+30</div>
          <div class="text-xs text-text-secondary mt-1">Clientes satisfechos</div>
        </div>
      </div>
    </ScrollReveal>

    <!-- Contact info -->
    <ScrollReveal delay="400ms">
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-6 text-sm text-text-secondary">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-cyan" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          Villavicencio, Colombia
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-cyan" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          <a href="tel:+573166299222" class="hover:text-accent-cyan transition-colors">+57 316 629 9222</a>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
