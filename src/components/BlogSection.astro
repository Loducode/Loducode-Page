---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import BlogCard from './BlogCard.astro';
import ScrollReveal from './ScrollReveal.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---
<section id="blog" class="py-20 lg:py-28 relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border-glass to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ScrollReveal>
      <SectionHeading
        subtitle="Ideas y tendencias"
        title="Desde Nuestro Blog"
        description="Analisis, guias y perspectivas sobre IA, Blockchain y desarrollo de software para lideres que toman decisiones informadas"
      />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post, i) => (
        <BlogCard
          title={post.data.title}
          date={post.data.date}
          author={post.data.author}
          image={post.data.image}
          excerpt={post.data.excerpt}
          category={post.data.category}
          slug={post.id}
          delay={`${i * 100}ms`}
        />
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full glass glass-hover text-sm font-medium text-text-primary"
      >
        Ver todos los artículos
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </div>
</section>
